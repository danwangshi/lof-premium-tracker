# ============================================
# LOF 基金监控系统 - 生产环境配置
# ============================================
# 复制此文件为 .env 并修改相应配置

# --------------------------------------------
# Flask 应用配置
# --------------------------------------------
HOST=0.0.0.0
PORT=5000
DEBUG=false
LOG_LEVEL=INFO
REFRESH_INTERVAL=300

# --------------------------------------------
# PostgreSQL 数据库配置
# --------------------------------------------
# 注意：DB_HOST 和 DB_PORT 是容器内部通信使用，不要修改
# DB_HOST: Docker 网络中的服务名（postgres）
# DB_PORT: PostgreSQL 容器内部端口（固定为 5432）
DB_HOST=postgres
DB_PORT=5432
DB_NAME=lof_funds
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD  # ⚠️ 请修改为强密码
DB_POOL_MIN=2
DB_POOL_MAX=10

# 数据库外部访问端口（从宿主机访问数据库的端口）
# 生产环境建议注释掉，不暴露数据库端口
# 如果需要从宿主机访问，可以取消注释并修改端口
DB_EXTERNAL_PORT=5433

# --------------------------------------------
# Nginx 配置
# --------------------------------------------
HTTP_PORT=80
HTTPS_PORT=443

# --------------------------------------------
# 企业微信通知配置（可选）
# --------------------------------------------
WEWORK_ENABLED=false
WEWORK_CONFIG=
WEWORK_SCHEDULE_ENABLED=true
WEWORK_SCHEDULE_TIMES=07:00,08:00
WEWORK_PREMIUM_THRESHOLD=3.0
WEWORK_DISCOUNT_THRESHOLD=1.5

# --------------------------------------------
# Docker 资源配置（可选）
# --------------------------------------------
# CPU 限制
# APP_CPU_LIMIT=1.0
# POSTGRES_CPU_LIMIT=0.5

# 内存限制
# APP_MEMORY_LIMIT=1G
# POSTGRES_MEMORY_LIMIT=512M
