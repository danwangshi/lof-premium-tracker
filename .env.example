# LOF Fund Tools - 环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# ═══════════════════════════════════════════════════════════
# Flask 应用配置
# ═══════════════════════════════════════════════════════════
HOST=0.0.0.0
PORT=5000
DEBUG=false

# 数据刷新间隔（秒），默认 5 分钟
REFRESH_INTERVAL=300

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════
# PostgreSQL 数据库配置
# ═══════════════════════════════════════════════════════════

# 方式一：使用 DATABASE_URL（Railway 等平台自动注入）
# DATABASE_URL=postgresql://user:password@host:port/dbname

# 方式二：使用独立的环境变量（本地开发推荐）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lof_funds
DB_USER=postgres
DB_PASSWORD=postgres123

# 连接池配置
DB_POOL_MIN=2
DB_POOL_MAX=10
